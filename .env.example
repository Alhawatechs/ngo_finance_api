# Copy this file to .env and fill in values. Never commit .env or real secrets.
APP_NAME="AADA ERP Finance"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# When API is consumed by Next.js on :3000, set this so logo/storage URLs work via proxy:
# ASSET_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aada_erp_finance
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@aada.org.af"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000
SESSION_DOMAIN=localhost

FRONTEND_URL=http://localhost:3000

# Finance Assistant: use "openai" or "deepseek"
ASSISTANT_PROVIDER=deepseek

# OpenAI (when ASSISTANT_PROVIDER=openai)
# Get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (when ASSISTANT_PROVIDER=deepseek)
# Get key from https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Optional: override default system prompt (keep short; context is appended automatically)
# ASSISTANT_SYSTEM_PROMPT="You are a helpful finance assistant..."

# Google Sheets API (for budget format import: paste sheet URL to import structure; many sheets/tabs supported)
# Create key at https://console.cloud.google.com/apis/credentials → Create credentials → API key
# Enable "Google Sheets API" for the project. The spreadsheet must be shared "Anyone with the link can view".
GOOGLE_SHEETS_API_KEY=
